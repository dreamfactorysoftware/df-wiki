[
  {
    "id": "deploy",
    "execute-command": "/etc/webhook/deploy.sh",
    "command-working-directory": "/repo",
    "response-message": "Deploy triggered",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv \"WEBHOOK_TOKEN\" }}",
        "parameter": {
          "source": "url",
          "name": "token"
        }
      }
    }
  }
]
